#!/usr/bin/env bash

# elo
# Wrapper para ejecutar el CLI de Elo Workbench

# Resolvemos el script real si se está ejecutando desde un symlink
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$( cd -P "$( dirname "$SOURCE" )" && pwd )"

# Calculamos la raíz del monorepo (2 niveles arriba de apps/elo-cli)
DIR="$( cd "$SCRIPT_DIR/../.." && pwd )"

RUNTIME_MODE="docker"
if [ -f "$DIR/.env" ]; then
    RUNTIME_MODE=$(grep "^ELO_RUNTIME_MODE=" "$DIR/.env" | cut -d '=' -f2- | tr -d '\r\n[:space:]')
fi

# Fallback default
if [ -z "$RUNTIME_MODE" ]; then
    RUNTIME_MODE="docker"
fi

if [ "$RUNTIME_MODE" == "native" ]; then
    # Ejecución local (sin Docker)
    if [ -f "$DIR/.env" ]; then
        set -a
        source "$DIR/.env"
        set +a
    fi
    cd "$DIR"
    # Execute locally via pnpm/tsx
    if command -v pnpm &> /dev/null; then
        pnpm run elo "$@"
    else
        npx tsx apps/elo-cli/src/index.ts "$@"
    fi
    exit $?
fi

# 1. Comprueba si docker está instalado
if ! command -v docker &> /dev/null; then
    echo -e "\033[0;31m❌ Docker no está instalado.\033[0m"
    echo "Por favor, instala Docker (Docker Desktop con backend WSL2 si estás en Windows)."
    exit 1
fi

# 2. Comprueba si el demonio de docker está corriendo
if ! docker info &> /dev/null; then
    echo -e "\033[0;31m❌ Docker no está ejecutándose.\033[0m"
    echo "Por favor, arranca el motor de Docker antes de continuar."
    exit 1
fi

# 3. Determinar si necesitamos consola interactiva (-t)
# Si estamos en TTY (ejecución normal) usamos -it, si estamos en un pipeline/CI, solo -i
if [ -t 0 ]; then
    DOCKER_INTERACTIVE_FLAGS="-it"
else
    DOCKER_INTERACTIVE_FLAGS="-i"
fi

# Resolvemos el script real si se está ejecutando desde un symlink
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$( cd -P "$( dirname "$SOURCE" )" && pwd )"

# Calculamos la raíz del monorepo (2 niveles arriba de apps/elo-cli)
DIR="$( cd "$SCRIPT_DIR/../.." && pwd )"

# 4. Propagar variables de entorno y montar vols
WORKSPACE_CONFIG="$DIR/elo-workspace/elo-config.json"
DOCKER_ENV_FLAGS=()
DOCKER_VOLUMES=("-v" "$DIR":"$DIR")

ENV_VARS=(
    "GOOGLE_AI_API_KEY"
    "OBSIDIAN_API_KEY"
    "MEMORY_PATH"
    "SERVER_AUTH_TOKEN"
    "NGROK_AUTHTOKEN"
    "OBSIDIAN_URL"
)

for var in "${ENV_VARS[@]}"; do
    if [ -n "${!var}" ]; then
        DOCKER_ENV_FLAGS+=("-e" "$var=${!var}")
    fi
done

if [ -f "$WORKSPACE_CONFIG" ] && command -v jq &> /dev/null; then
    MEMORIES=$(jq -r '.markdownMemories? // empty | .[]' "$WORKSPACE_CONFIG")
    while IFS= read -r memory; do
        if [ -n "$memory" ]; then
            DOCKER_VOLUMES+=("-v" "$memory":"$memory")
        fi
    done <<< "$MEMORIES"
fi

# 5. Delegar el comando al contenedor de Elo CLI
docker run --rm $DOCKER_INTERACTIVE_FLAGS \
  -e npm_config_update_notifier=false \
  "${DOCKER_ENV_FLAGS[@]}" \
  "${DOCKER_VOLUMES[@]}" \
  -v /var/run/docker.sock:/var/run/docker.sock \
  --add-host host.docker.internal:host-gateway \
  -w "$DIR" \
  --network host \
  elo-cli-env "$@"
